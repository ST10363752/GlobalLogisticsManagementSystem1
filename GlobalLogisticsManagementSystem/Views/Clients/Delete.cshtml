@model GlobalLogisticsManagementSystem.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<div class="container">
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="fas fa-trash me-2"></i>Delete Client</h5>
        </div>
        <div class="card-body">
            <h5>Are you sure you want to delete this client?</h5>

            <dl class="row mt-4">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

                <dt class="col-sm-3">Contact Details</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ContactDetails)</dd>

                <dt class="col-sm-3">Region</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Region)</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="ClientId" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </form>
        </div>
    </div>
</div>