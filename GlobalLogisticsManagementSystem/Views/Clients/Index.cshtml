@model IEnumerable<GlobalLogisticsManagementSystem.Models.Client>

@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="color: #0d5c5c; font-weight: 600;">Clients</h4>
        <p class="text-muted small mb-0">Manage your freight and logistics clients</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>New Client</a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr><th>Company Name</th><th>Contact</th><th>Region</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><i class="fas fa-building me-1 text-muted"></i>@item.Name</td>
                                <td>@item.ContactDetails</td>
                                <td>@item.Region</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.ClientId" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-action="Details" asp-route-id="@item.ClientId" class="btn btn-sm btn-outline-secondary">Details</a>
                                    <a asp-action="Delete" asp-route-id="@item.ClientId" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <p class="text-muted small mb-0">No clients found.</p>
            </div>
        }
    </div>
</div>