@model GlobalLogisticsManagementSystem.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<div class="container">
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Contract</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="ContractId" />
                <input type="hidden" asp-for="SignedAgreementPath" />
                <input type="hidden" asp-for="SignedAgreementFileName" />

                <div class="mb-3">
                    <label asp-for="ClientId" class="form-label"></label>
                    <select asp-for="ClientId" class="form-select" asp-items="ViewBag.ClientId">
                        <option value="">-- Select Client --</option>
                    </select>
                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="Draft">Draft</option>
                        <option value="Active">Active</option>
                        <option value="Expired">Expired</option>
                        <option value="OnHold">On Hold</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ServiceLevel" class="form-label"></label>
                    <select asp-for="ServiceLevel" class="form-select">
                        <option value="Standard">Standard</option>
                        <option value="Premium">Premium</option>
                        <option value="Express">Express</option>
                    </select>
                    <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                </div>

                @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                {
                    <div class="mb-3">
                        <label class="form-label">Current Signed Agreement</label>
                        <div>
                            <a href="@Url.Action("DownloadFile", "Contracts", new { id = Model.ContractId })" class="btn btn-info btn-sm">
                                <i class="fas fa-download"></i> Download Current File
                            </a>
                            <span class="text-muted ms-2">@Model.SignedAgreementFileName</span>
                        </div>
                    </div>
                }

                <div class="mb-3">
                    <label for="pdfFile" class="form-label">Replace Signed Agreement (PDF only, max 5MB)</label>
                    <input type="file" name="pdfFile" class="form-control" accept=".pdf" />
                    <small class="text-muted">Leave empty to keep current file. Upload new PDF to replace.</small>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}