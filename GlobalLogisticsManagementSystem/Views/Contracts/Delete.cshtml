@model GlobalLogisticsManagementSystem.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<div class="container">
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="fas fa-trash me-2"></i>Delete Contract</h5>
        </div>
        <div class="card-body">
            <h5>Are you sure you want to delete this contract?</h5>

            <dl class="row mt-4">
                <dt class="col-sm-3">Client</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Client.Name)</dd>

                <dt class="col-sm-3">Start Date</dt>
                <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

                <dt class="col-sm-3">End Date</dt>
                <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>

                <dt class="col-sm-3">Service Level</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ServiceLevel)</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="ContractId" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </form>
        </div>
    </div>
</div>