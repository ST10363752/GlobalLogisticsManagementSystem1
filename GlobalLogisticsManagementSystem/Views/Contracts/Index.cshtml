@model IEnumerable<GlobalLogisticsManagementSystem.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="color: #1a2c3e; font-weight: 600;">Contracts</h4>
        <p class="text-muted small mb-0">Manage all logistics contracts</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>New Contract</a>
</div>

<!-- Search Form -->
<div class="search-form">
    <form asp-action="Search" method="get" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="small fw-semibold">Start Date From</label>
            <input type="date" name="startDate" class="form-control form-control-sm" value="@ViewBag.StartDate" />
        </div>
        <div class="col-md-3">
            <label class="small fw-semibold">End Date To</label>
            <input type="date" name="endDate" class="form-control form-control-sm" value="@ViewBag.EndDate" />
        </div>
        <div class="col-md-3">
            <label class="small fw-semibold">Status</label>
            <select name="status" class="form-select form-select-sm">
                <option value="">All Status</option>
                <option value="Active" selected="@(ViewBag.SelectedStatus == "Active")">Active</option>
                <option value="Draft" selected="@(ViewBag.SelectedStatus == "Draft")">Draft</option>
                <option value="Expired" selected="@(ViewBag.SelectedStatus == "Expired")">Expired</option>
                <option value="OnHold" selected="@(ViewBag.SelectedStatus == "OnHold")">On Hold</option>
            </select>
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="fas fa-search me-1"></i>Search</button>
        </div>
    </form>
    @if (ViewBag.IsSearchResult == true)
    {
        <div class="mt-2">
            <a asp-action="Index" class="text-decoration-none small">Clear Filters</a>
        </div>
    }
</div>

<!-- Contracts Table -->
<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr><th>Client</th><th>Start Date</th><th>End Date</th><th>Status</th><th>Service Level</th><th>Agreement</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><i class="fas fa-building me-1 text-muted"></i>@item.Client?.Name</td>
                                <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                                <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge badge-active">Active</span>
                                    }
                                    else if (item.Status == "Expired")
                                    {

                                        <span class="badge badge-expired">Expired</span>
                                    }
                                    else if (item.Status == "Draft")
                                    {

                                        <span class="badge badge-draft">Draft</span>
                                    }
                                    else
                                    {

                                        <span class="badge badge-onhold">On Hold</span>
                                    }
                                </td>
                                <td><span class="badge bg-secondary">@item.ServiceLevel</span></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.SignedAgreementPath))
                                    {
                                        <a asp-action="DownloadFile" asp-route-id="@item.ContractId" class="btn btn-sm btn-outline-secondary"><i class="fas fa-download"></i> PDF</a>
                                    }
                                    else
                                    {

                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.ContractId" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.ContractId" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <p class="text-muted small mb-0">No contracts found.</p>
            </div>
        }
    </div>
</div>