@model GlobalLogisticsManagementSystem.Models.Contract

@{
    ViewData["Title"] = "Contract Details";
}

<div class="container">
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Contract Details</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Client</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Client.Name)</dd>

                <dt class="col-sm-3">Start Date</dt>
                <dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>

                <dt class="col-sm-3">End Date</dt>
                <dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>

                <dt class="col-sm-3">Service Level</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.ServiceLevel)</dd>

                <dt class="col-sm-3">Signed Agreement</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                    {
                        <a href="@Url.Action("DownloadFile", "Contracts", new { id = Model.ContractId })" class="btn btn-info">
                            <i class="fas fa-download"></i> Download Signed Agreement
                        </a>
                        <br />
                        <small class="text-muted">Filename: @Model.SignedAgreementFileName</small>
                    }
                    else
                    {
                        <span class="text-muted">No signed agreement uploaded</span>
                    }
                </dd>
            </dl>
            <a asp-action="Edit" asp-route-id="@Model?.ContractId" class="btn btn-primary">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>