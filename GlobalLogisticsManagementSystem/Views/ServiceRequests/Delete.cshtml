@model GlobalLogisticsManagementSystem.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<div class="container">
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0"><i class="fas fa-trash me-2"></i>Delete Service Request</h5>
        </div>
        <div class="card-body">
            <h5>Are you sure you want to delete this service request?</h5>

            <dl class="row mt-4">
                <dt class="col-sm-3">Contract</dt>
                <dd class="col-sm-9">@Model.Contract?.Client?.Name</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>

                <dt class="col-sm-3">Amount (USD)</dt>
                <dd class="col-sm-9">$@Model.AmountUSD.ToString("N2")</dd>

                <dt class="col-sm-3">Amount (ZAR)</dt>
                <dd class="col-sm-9">R@Model.AmountZAR.ToString("N2")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>

                <dt class="col-sm-3">Request Date</dt>
                <dd class="col-sm-9">@Model.RequestDate.ToShortDateString()</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="ServiceRequestId" />
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </form>
        </div>
    </div>
</div>