@model GlobalLogisticsManagementSystem.Models.ServiceRequest

@{
    ViewData["Title"] = "Service Request Details";
}

<div class="container">
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Service Request Details</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Contract</dt>
                <dd class="col-sm-9">@Model.Contract?.Client?.Name</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Description)</dd>

                <dt class="col-sm-3">Amount (USD)</dt>
                <dd class="col-sm-9">$@Model.AmountUSD.ToString("N2")</dd>

                <dt class="col-sm-3">Amount (ZAR)</dt>
                <dd class="col-sm-9">R@Model.AmountZAR.ToString("N2")</dd>

                <dt class="col-sm-3">Exchange Rate Used</dt>
                <dd class="col-sm-9">@Model.ExchangeRateUsed</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Status)</dd>

                <dt class="col-sm-3">Request Date</dt>
                <dd class="col-sm-9">@Model.RequestDate.ToShortDateString()</dd>
            </dl>
            <a asp-action="Edit" asp-route-id="@Model?.ServiceRequestId" class="btn btn-primary">Edit</a>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </div>
</div>