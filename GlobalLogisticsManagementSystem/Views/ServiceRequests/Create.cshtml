@model GlobalLogisticsManagementSystem.Models.ServiceRequest

@{
    ViewData["Title"] = "Create Service Request";
}

<div class="container">
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Create New Service Request</h5>
        </div>
        <div class="card-body">
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            <div class="alert alert-info">
                <strong>Note:</strong> Only contracts with <strong>Active</strong> status can create service requests.
                <br />
                <strong>Exchange Rate:</strong> 1 USD = 19.00 ZAR
            </div>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="ContractId" class="form-label">Contract</label>
                    <select asp-for="ContractId" class="form-select" asp-items="@(ViewBag.ContractId as SelectList)">
                        <option value="">-- Select a Contract --</option>
                    </select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AmountUSD" class="form-label">Amount (USD)</label>
                    <input asp-for="AmountUSD" class="form-control" id="AmountUSD" />
                    <span asp-validation-for="AmountUSD" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Amount (ZAR)</label>
                    <input type="text" id="AmountZAR" class="form-control" readonly />
                </div>

                <input type="hidden" asp-for="AmountZAR" />
                <input type="hidden" asp-for="ExchangeRateUsed" value="19.00" />
                <input type="hidden" asp-for="Status" value="Pending" />
                <input type="hidden" asp-for="RequestDate" />

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("AmountUSD").addEventListener("input", function() {
            var usd = parseFloat(this.value) || 0;
            var zar = usd * 19.00;
            document.getElementById("AmountZAR").value = zar.toFixed(2);
            document.querySelector("input[name='AmountZAR']").value = zar.toFixed(2);
        });
    </script>
}