@model IEnumerable<GlobalLogisticsManagementSystem.Models.ServiceRequest>

@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="color: #1a2c3e; font-weight: 600;">Service Requests</h4>
        <p class="text-muted small mb-0">Track and manage service requests</p>
    </div>
    <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>New Request</a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr><th>ID</th><th>Contract</th><th>Description</th><th>USD</th><th>ZAR</th><th>Status</th><th>Date</th><th>Actions</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>#@item.ServiceRequestId</td>
                                <td>@item.Contract?.Client?.Name</td>
                                <td>@item.Description</td>
                                <td>$@item.AmountUSD.ToString("N0")</td>
                                <td>R @item.AmountZAR.ToString("N0")</td>
                                <td><span class="badge @(item.Status == "Pending" ? "badge-pending" : "badge-completed")">@item.Status</span></td>
                                <td>@item.RequestDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.ServiceRequestId" class="btn btn-sm btn-outline-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <p class="text-muted small mb-0">No service requests found.</p>
            </div>
        }
    </div>
</div>