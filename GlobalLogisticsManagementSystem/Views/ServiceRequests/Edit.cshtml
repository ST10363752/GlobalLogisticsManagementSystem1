@model GlobalLogisticsManagementSystem.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="container">
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Service Request</h5>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="ServiceRequestId" />

                <div class="mb-3">
                    <label asp-for="ContractId" class="form-label"></label>
                    <select asp-for="ContractId" class="form-select" asp-items="ViewBag.ContractId"></select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AmountUSD" class="form-label"></label>
                    <input asp-for="AmountUSD" class="form-control" />
                    <span asp-validation-for="AmountUSD" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AmountZAR" class="form-label"></label>
                    <input asp-for="AmountZAR" class="form-control" />
                    <span asp-validation-for="AmountZAR" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label"></label>
                    <select asp-for="Status" class="form-select">
                        <option value="Pending">Pending</option>
                        <option value="Completed">Completed</option>
                    </select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <button type="submit" class="btn btn-primary">Save</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}